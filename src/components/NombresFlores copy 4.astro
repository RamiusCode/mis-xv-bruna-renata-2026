---
// Componente Astro para XV Años - Diseño compacto para todas las pantallas
---

<section
  class="relative text-black w-full h-screen overflow-hidden flex items-center justify-center"
>
  <div class="relative w-full max-w-[480px] h-screen mx-auto">
    <!-- FONDO -->
    <div class="absolute inset-0 w-full h-full z-0">
      <div
        class="absolute inset-0 w-full h-full"
        style="background-image: url('/imagenes/fondoPrincipal.png'); background-size: cover; background-position: center;"
      >
      </div>
      <img
        src="/imagenes/Fondo.webp"
        alt="Fondo mágico"
        class="w-full h-full absolute top-0 left-0"
        id="imagen-fondo"
        style="object-fit: cover; object-position: top center;"
      />
    </div>

    <!-- FLORES SUPERIORES + CORONA + TEXTO DECORATIVO -->
    <div class="absolute top-0 left-0 w-full z-10" id="flores-superiores">
      <div class="relative w-full flex justify-between items-start">
        <div id="flores-sup-izq" class="w-36 sm:w-44 flex-shrink-0">
          <img
            src="/imagenes/FloresIzquierda.webp"
            alt="Flores superiores izquierda"
            class="w-full h-auto object-contain"
          />
        </div>
        <div id="flores-sup-der" class="w-36 sm:w-44 flex-shrink-0">
          <img
            src="/imagenes/FloresDerecha.webp"
            alt="Flores superiores derecha"
            class="w-full h-auto object-contain"
          />
        </div>
      </div>

      <!-- CORONA -->
      <div
        class="absolute left-1/2 -translate-x-1/2 top-[95px] sm:top-[55px] z-50"
        id="corona"
      >
        <img
          src="/imagenes/Corona.webp"
          alt="Corona de quinceañera"
          class="w-24 sm:w-22 h-auto object-contain mx-auto"
        />
      </div>

      <!-- TEXTO DECORATIVO CURSIVO -->
      <!-- text-xl = ~1.25rem en celular, texto legible sin ser gigante -->
      <div
        class="absolute left-1/2 pt-4 -translate-x-1/2 top-[172px] sm:top-[110px] z-50 px-6 w-full"
        id="texto-decorativo-container"
      >
        <p
          class="font-great-vibes text-center leading-snug text-2xl sm:text-2xl"
          id="texto-decorativo"
          style="
            color: #3c633c;
            text-shadow:
              0 0 10px rgba(255,255,255,0.95),
              0 0 22px rgba(255,255,255,0.8),
              0 2px 6px rgba(255,255,255,0.8);
            letter-spacing: 0.02em;
          "
        >
          Entre luciérnagas y melodías,<br />
          mi sueño cobra vida esta noche
        </p>
      </div>
    </div>

    <!-- NOMBRE DE LA QUINCEAÑERA -->
    <div class="absolute top-[270px] sm:top-[210px] left-0 w-full">
      <div class="flex justify-center w-full">
        <div class="text-center z-10 w-full px-2">
          <div class="relative w-full" id="nombre-container">
            <div class="relative z-30">
              <!-- text-7xl = ~4.5rem, grande y legible en celular -->
              <h2
                class="font-great-vibes tracking-wide break-words text-7xl sm:text-8xl"
                id="nombre-quinceanera"
                style="
  color: #6B8E6B;
  text-shadow:
    0 0 15px rgba(255, 255, 255, 1),
    0 0 30px rgba(255, 255, 255, 0.8),
    0 0 50px rgba(255, 255, 255, 0.4),
    0 4px 10px rgba(0, 0, 0, 0.7);
  line-height: 1.05;
"
              >
              </h2>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- DULCES 15 -->
    <div
      class="absolute left-1/2 -translate-x-1/2 z-30"
      id="dulces-15-container"
      style="top: 490px;"
    >
      <!-- text-4xl = ~2.25rem para "Dulces" -->
      <p
        class="font-great-vibes text-center leading-none font-bold text-4xl sm:text-5xl"
        style="
          color: #f5d060;
          text-shadow:
            0 2px 0 #4a2800,
            0 3px 8px rgba(0,0,0,0.95),
            0 0 22px rgba(255,210,50,0.45);
        "
      >
        Dulces
      </p>
      <!-- text-6xl = ~3.75rem para "15" -->
      <p
        class="font-great-vibes text-center leading-none font-bold text-6xl sm:text-7xl"
        style="
          color: #f5d060;
          text-shadow:
            0 2px 0 #4a2800,
            0 4px 12px rgba(0,0,0,0.95),
            0 0 30px rgba(255,210,50,0.5);
        "
      >
        15
      </p>
    </div>

    <!-- MARIPOSAS + PRINCESA -->
    <div
      class="absolute bottom-0 right-0 w-full h-[50%] flex justify-end items-end"
      id="princesa-container"
    >
      <div
        id="mariposa-1"
        class="absolute left-[8%] sm:left-[10%] top-[25%] sm:top-[30%] z-10"
      >
        <img
          src="/imagenes/MariposaVerde.webp"
          alt="Mariposa"
          class="w-12 h-12 sm:w-14 sm:h-14 object-contain mariposa-volando"
        />
      </div>
      <div
        id="mariposa-2"
        class="absolute left-[5%] sm:left-[7%] top-[60%] sm:top-[65%] z-10"
      >
        <img
          src="/imagenes/MariposaVerde.webp"
          alt="Mariposa"
          class="w-14 h-14 sm:w-16 sm:h-16 object-contain mariposa-volando"
        />
      </div>
      <div
        id="mariposa-3"
        class="absolute left-[15%] sm:left-[18%] top-[45%] sm:top-[50%] z-10"
      >
        <img
          src="/imagenes/MariposaVerde.webp"
          alt="Mariposa"
          class="w-10 h-10 sm:w-12 sm:h-12 object-contain mariposa-volando"
        />
      </div>
      <div
        id="mariposa-4"
        class="absolute left-[25%] sm:left-[38%] top-[30%] sm:top-[25%] z-10"
      >
        <img
          src="/imagenes/MariposaVerde.webp"
          alt="Mariposa"
          class="w-11 h-11 object-contain mariposa-volando"
        />
      </div>
      <div
        id="mariposa-5"
        class="absolute left-[45%] sm:left-[48%] top-[50%] sm:top-[55%] z-10"
      >
        <img
          src="/imagenes/MariposaVerde.webp"
          alt="Mariposa"
          class="w-9 h-9 sm:w-11 sm:h-11 object-contain mariposa-volando"
        />
      </div>
      <div
        id="mariposa-6"
        class="absolute left-[28%] sm:left-[40%] top-[70%] sm:top-[75%] z-10"
      >
        <img
          src="/imagenes/MariposaVerde.webp"
          alt="Mariposa"
          class="w-8 h-10 sm:w-12 sm:h-12 object-contain mariposa-volando"
        />
      </div>
      <div
        id="mariposa-7"
        class="absolute right-[45%] sm:right-[32%] top-[35%] sm:top-[40%] z-10"
      >
        <img
          src="/imagenes/MariposaVerde.webp"
          alt="Mariposa"
          class="w-8 h-12 sm:w-14 sm:h-14 object-contain mariposa-volando"
        />
      </div>
      <div
        id="mariposa-8"
        class="absolute right-[25%] sm:right-[28%] top-[65%] sm:top-[70%] z-10"
      >
        <img
          src="/imagenes/MariposaVerde.webp"
          alt="Mariposa"
          class="w-8 h-8 sm:w-10 sm:h-10 object-contain mariposa-volando"
        />
      </div>

      <!-- PRINCESA -->
      <div id="princesa" class="relative z-20 w-[220px] sm:w-[280px] mb-0">
        <img
          src="/imagenes/PrincesaTiana.webp"
          alt="Princesa Tiana"
          class="w-full h-auto object-contain"
        />
      </div>
    </div>

    <!-- FLORES INFERIORES -->
    <div
      class="absolute left-0 w-full z-30"
      id="flores-inferiores"
      style="bottom: -5%;"
    >
      <img
        src="/imagenes/FloresAbajo.webp"
        alt="Flores decorativas inferiores"
        class="w-full h-auto object-contain"
      />
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  let animacionesEjecutadas = false;

  document.addEventListener("DOMContentLoaded", () => {
    if (animacionesEjecutadas) return;
    animacionesEjecutadas = true;

    gsap.config({ force3D: true, nullTargetWarn: false });

    const animacionConfig = {
      flores: { duracion: 1, delay: 0 },
      corona: { duracion: 1.2, delay: 0.3 },
      texto: { duracion: 1, delay: 0.5 },
      nombre: { duracion: 0.8, delay: 0.8, stagger: 0.06 },
      dulces: { duracion: 1, delay: 1.1 },
      princesa: { duracion: 1.5, delay: 1.2 },
      mariposas: { duracion: 1, delay: 1.4, stagger: 0.15 },
      floresInf: { duracion: 1, delay: 0 },
    };

    gsap.fromTo(
      "#flores-sup-izq",
      { opacity: 0, x: -100, rotation: -15 },
      {
        opacity: 1,
        x: 0,
        rotation: 0,
        duration: animacionConfig.flores.duracion,
        ease: "power2.out",
      },
    );
    gsap.fromTo(
      "#flores-sup-der",
      { opacity: 0, x: 100, rotation: 15 },
      {
        opacity: 1,
        x: 0,
        rotation: 0,
        duration: animacionConfig.flores.duracion,
        ease: "power2.out",
      },
    );

    gsap.fromTo(
      "#corona",
      { opacity: 0, y: -50, scale: 0.3 },
      {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: animacionConfig.corona.duracion,
        ease: "elastic.out(1, 0.5)",
        delay: animacionConfig.corona.delay,
      },
    );
    gsap.to("#corona", {
      y: -3,
      duration: 2.5,
      ease: "sine.inOut",
      yoyo: true,
      repeat: -1,
      delay: 2,
    });

    gsap.fromTo(
      "#texto-decorativo-container",
      { opacity: 0, y: -20 },
      {
        opacity: 1,
        y: 0,
        duration: animacionConfig.texto.duracion,
        ease: "power2.out",
        delay: animacionConfig.texto.delay,
      },
    );

    const animarNombre = (texto) => {
      const contenedor = document.getElementById("nombre-quinceanera");
      if (!contenedor) return;

      const lineas = texto.split("|");
      contenedor.innerHTML = lineas
        .map((linea, index) => {
          const letras = linea
            .split("")
            .map(
              (letra) =>
                `<span class="letra-cascada" style="opacity: 0; display: inline-block;">${letra === " " ? "&nbsp;" : letra}</span>`,
            )
            .join("");
          const style =
            index < lineas.length - 1
              ? "display: block; margin-bottom: 0.15em;"
              : "display: block;";
          return `<div style="${style}">${letras}</div>`;
        })
        .join("");

      gsap.fromTo(
        ".letra-cascada",
        { opacity: 0, y: 30, scale: 0.5, rotation: 10 },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          rotation: 0,
          duration: animacionConfig.nombre.duracion,
          ease: "elastic.out(1, 0.6)",
          stagger: { each: animacionConfig.nombre.stagger, from: "start" },
          delay: animacionConfig.nombre.delay,
        },
      );
    };

    animarNombre("Bruna|Renata");

    gsap.fromTo(
      "#dulces-15-container",
      { opacity: 0, scale: 0.7, y: 20 },
      {
        opacity: 1,
        scale: 1,
        y: 0,
        duration: 1,
        ease: "back.out(1.4)",
        delay: animacionConfig.dulces.delay,
      },
    );
    gsap.to("#dulces-15-container", {
      y: -4,
      duration: 3,
      ease: "sine.inOut",
      yoyo: true,
      repeat: -1,
      delay: 2.5,
    });

    gsap.fromTo(
      "#princesa",
      { opacity: 0, x: 150, y: 30, scale: 0.7 },
      {
        opacity: 1,
        x: 0,
        y: 0,
        scale: 1,
        duration: animacionConfig.princesa.duracion,
        ease: "power3.out",
        delay: animacionConfig.princesa.delay,
      },
    );
    gsap.to("#princesa", {
      y: -8,
      duration: 3.5,
      ease: "sine.inOut",
      yoyo: true,
      repeat: -1,
      delay: 2,
    });

    const mariposas = [
      "#mariposa-1",
      "#mariposa-2",
      "#mariposa-3",
      "#mariposa-4",
      "#mariposa-5",
      "#mariposa-6",
      "#mariposa-7",
      "#mariposa-8",
    ];
    const isMobile = window.innerWidth < 640;

    mariposas.forEach((m, i) => {
      gsap.fromTo(
        m,
        { opacity: 0, scale: 0, x: -50, y: -50, rotation: -180 },
        {
          opacity: 1,
          scale: 1,
          x: 0,
          y: 0,
          rotation: 0,
          duration: animacionConfig.mariposas.duracion,
          ease: "back.out(1.5)",
          delay:
            animacionConfig.mariposas.delay +
            i * animacionConfig.mariposas.stagger,
        },
      );

      gsap
        .timeline({ repeat: -1, delay: 2 + i * 0.3 })
        .to(m, {
          x: isMobile ? "random(-15,15)" : "random(-25,25)",
          y: isMobile ? "random(-12,12)" : "random(-20,20)",
          rotation: "random(-15,15)",
          duration: "random(2.5,3.5)",
          ease: "sine.inOut",
        })
        .to(m, {
          x: isMobile ? "random(-15,15)" : "random(-25,25)",
          y: isMobile ? "random(-12,12)" : "random(-20,20)",
          rotation: "random(-15,15)",
          duration: "random(2.5,3.5)",
          ease: "sine.inOut",
        })
        .to(m, {
          x: 0,
          y: 0,
          rotation: 0,
          duration: "random(2.5,3.5)",
          ease: "sine.inOut",
        });

      gsap.to(`${m} img`, {
        scaleX: 0.9,
        duration: 0.15,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: 2 + i * 0.2,
      });
    });

    gsap.fromTo(
      "#flores-inferiores",
      { opacity: 0, y: 50 },
      {
        opacity: 0.9,
        y: 0,
        duration: animacionConfig.floresInf.duracion,
        ease: "power2.out",
      },
    );
  });
</script>

<style>
  * {
    -webkit-user-select: none;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  section {
    width: 100vw;
    height: 100vh;
    min-height: 100vh;
    max-width: 100vw;
    position: relative;
    overflow: visible;
    touch-action: pan-y;
  }

  section > div {
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.1);
  }

  #flores-superiores,
  #nombre-container,
  #princesa-container,
  #corona,
  #princesa,
  #mariposa-1,
  #mariposa-2,
  #mariposa-3,
  #mariposa-4,
  #mariposa-5,
  #mariposa-6,
  #mariposa-7,
  #mariposa-8,
  #flores-sup-izq,
  #flores-sup-der,
  #flores-inferiores,
  #dulces-15-container {
    will-change: transform, opacity;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  #imagen-fondo {
    object-fit: cover;
    object-position: center;
    pointer-events: none;
  }

  #flores-inferiores {
    overflow: visible;
    bottom: -5% !important;
  }

  #flores-inferiores img {
    display: block;
    width: 100%;
    height: auto;
  }

  .mariposa-volando {
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
    transition: filter 0.3s ease;
  }

  .letra-cascada {
    transition: all 0.3s ease;
    position: relative;
    cursor: default;
    display: inline-block;
    touch-action: none;
  }

  .letra-cascada:hover {
    transform: translateY(-5px) scale(1.15) !important;
    color: #fff5c0 !important;
  }

  @keyframes brillo-magico {
    0%,
    100% {
      filter: brightness(1);
    }
    50% {
      filter: brightness(1.4) drop-shadow(0 0 12px rgba(255, 255, 255, 0.6));
    }
  }

  #corona img {
    animation: brillo-magico 3s ease-in-out infinite;
  }

  @media (max-width: 640px) {
    section {
      max-height: 100vh;
    }
  }
</style>
