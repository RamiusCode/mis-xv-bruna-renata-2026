              </div>
            </div>
          </div>

          <!-- MENSAJE INFERIOR -->
          <div class="text-center mt-8 sm:mt-10">
            <div
              class="inline-flex items-center gap-3 bg-gradient-to-r from-[#6B8E6B]/10 to-[#D4AF37]/10 backdrop-blur-sm rounded-full px-6 py-3 shadow-md"
            >
              <img
                src="/imagenes/FloresIndividuales.webp"
                alt="Flor"
                class="w-5 h-5 sm:w-6 sm:h-6 object-contain animate-pulse"
              />
              <p
