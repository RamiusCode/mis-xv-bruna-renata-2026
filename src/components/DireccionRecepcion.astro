---
// DireccionRecepcion.astro
---

<section class="py-4 pb-16 px-4 relative">
    <div class="max-w-xl mx-auto text-center relative">
        <!-- 🏛️ ICONO DIRECCIÓN CON FLORES EN LOS BORDES -->
        <div class="relative mb-4" id="icono-recepcion">
            <!-- 🌸 FLORES EN EL BORDE IZQUIERDO (PEGADA AL BORDE DEL CONTENEDOR) -->
            <div
                class="absolute left-0 top-1/3 -translate-y-1/2 w-12 pointer-events-none -ml-6 sm:-ml-7 md:-ml-8"
                id="flores-recep-izq"
            >
                <img
                    src="/imagenes/FloresLaterales.webp"
                    alt="Flores decorativas izquierda"
                    class="w-full h-auto object-contain"
                />
            </div>

            <!-- TÍTULO RECEPCIÓN -->
            <div class="mb-2" id="titulo-recepcion">
                <h2
                    class="font-charm text-2xl md:text-3xl text-[#D4AF37] font-bold tracking-wide"
                >
                    DIRECCIÓN
                </h2>
            </div>

            <!-- ICONO CENTRAL -->
            <div class="flex justify-center">
                <!-- Reusamos el mismo icono o uno de fiesta si hubiera, pero por ahora el mismo icono de dirección está bien o similar -->
                <img
                    src="/imagenes/IconoDireccionFlores.webp"
                    alt="Icono de recepción"
                    class="w-48 h-24 md:w-28 md:h-28 lg:w-32 lg:h-32 object-contain"
                />
            </div>

            <!-- 🌸 FLORES EN EL BORDE DERECHO (PEGADA AL BORDE DEL CONTENEDOR) -->
            <div
                class="absolute right-0 top-1/3 -translate-y-1/2 w-12 pointer-events-none -mr-6 sm:-mr-7 md:-mr-8"
                id="flores-recep-der"
            >
                <img
                    src="/imagenes/FloresLaterales.webp"
                    alt="Flores decorativas derecha"
                    class="w-full h-auto object-contain scale-x-[-1]"
                />
            </div>
        </div>

        <!-- INFORMACIÓN DE UBICACIÓN -->
        <div class="mb-2" id="info-recepcion">
            <p
                class="font-charm text-xl md:text-lg text-[#6B8E6B] leading-relaxed mb-2"
            >
                <b class="text-[#D4AF37] text-2xl">Salón de Eventos "Miel"</b
                ><br />

                <p
                    class="font-charm text-xl md:text-lg text-[#6B8E6B] leading-relaxed mb-2"
                >
                    Av. Radial 13, esquina Hugo Wende,<br /> Santa Cruz de la Sierra
                </p>

                <span
                    class="font-charm text-xl md:text-lg text-[#6B8E6B] leading-relaxed mb-2 font-bold"
                    >Hora: 19:30</span
                >
            </p>
        </div>

        <!-- BOTÓN VER UBICACIÓN -->
        <div class="flex justify-center" id="boton-ubicacion-recepcion">
            <a
                href="https://maps.app.goo.gl/NA9txwuyT2Cic5NC8"
                target="_blank"
                rel="noopener noreferrer"
            >
                <img
                    src="/imagenes/BtnUbicacion.webp"
                    alt="Ver ubicación en el mapa"
                    class="w-56 md:w-56 lg:w-64 h-auto object-contain cursor-pointer transition-transform duration-300 hover:scale-105"
                />
            </a>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            // Estado inicial
            gsap.set("#icono-recepcion", { opacity: 0, scale: 0.8 });
            gsap.set("#titulo-recepcion", { opacity: 0, scale: 0.9 });
            gsap.set("#info-recepcion", { opacity: 0, scale: 0.9 });
            gsap.set("#boton-ubicacion-recepcion", { opacity: 0, scale: 0.9 });
            gsap.set("#flores-recep-izq", { opacity: 0, x: -30 });
            gsap.set("#flores-recep-der", { opacity: 0, x: 30 });

            // ✨ ANIMACIÓN SIMULTÁNEA - TODO AL MISMO TIEMPO
            ScrollTrigger.create({
                trigger: "#icono-recepcion",
                start: "top 85%",
                end: "top 20%",
                onEnter: () => {
                    const tl = gsap.timeline();

                    // TODO aparece al mismo tiempo
                    tl.to(
                        "#icono-recepcion, #flores-recep-izq, #flores-recep-der, #titulo-recepcion, #info-recepcion, #boton-ubicacion-recepcion",
                        {
                            opacity: 1,
                            duration: 1,
                            ease: "power2.out",
                        },
                    )
                        // Animaciones individuales (simultáneas)
                        .to(
                            "#icono-recepcion",
                            {
                                scale: 1,
                                duration: 1,
                                ease: "back.out(1.5)",
                            },
                            "<",
                        )
                        .to(
                            "#flores-recep-izq",
                            {
                                x: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            "<",
                        )
                        .to(
                            "#flores-recep-der",
                            {
                                x: 0,
                                duration: 1,
                                ease: "power2.out",
                            },
                            "<",
                        )
                        .to(
                            "#titulo-recepcion, #info-recepcion, #boton-ubicacion-recepcion",
                            {
                                scale: 1,
                                duration: 1,
                                ease: "back.out(1.2)",
                            },
                            "<",
                        );
                },
                onLeaveBack: () => {
                    // Salida simultánea
                    const tl = gsap.timeline();

                    tl.to(
                        "#icono-recepcion, #flores-recep-izq, #flores-recep-der, #titulo-recepcion, #info-recepcion, #boton-ubicacion-recepcion",
                        {
                            opacity: 0,
                            duration: 0.5,
                            ease: "power2.in",
                        },
                    )
                        .to(
                            "#icono-recepcion",
                            {
                                scale: 0.8,
                                duration: 0.5,
                                ease: "power2.in",
                            },
                            "<",
                        )
                        .to(
                            "#flores-recep-izq",
                            {
                                x: -30,
                                duration: 0.5,
                                ease: "power2.in",
                            },
                            "<",
                        )
                        .to(
                            "#flores-recep-der",
                            {
                                x: 30,
                                duration: 0.5,
                                ease: "power2.in",
                            },
                            "<",
                        )
                        .to(
                            "#titulo-recepcion, #info-recepcion, #boton-ubicacion-recepcion",
                            {
                                scale: 0.9,
                                duration: 0.5,
                                ease: "power2.in",
                            },
                            "<",
                        );
                },
            });

            console.log("📍🌸 Sección de Recepción inicializada");
        });
    }
</script>

<style>
    /* Asegurar que las flores en los bordes tengan movimiento fluido */
    .flores-borde-izq,
    .flores-borde-der {
        will-change: transform;
        transition: all 0.3s ease;
    }
</style>
