          ></ellipse>
          <ellipse cx="60" cy="60" rx="40" ry="28" fill="#D4AF37" opacity="0.3"
          ></ellipse>
          <circle cx="60" cy="60" r="12" fill="#D4AF37" opacity="0.8"></circle>
        </svg>
      </div>

      <!-- DECORACIÓN DERECHA: HOJAS DE NENÚFAR -->
      <div
        class="absolute right-0 top-1/2 -translate-y-1/2 w-20 sm:w-20 md:w-20 pointer-events-none z-0 -mr-10 sm:-mr-10 md:-mr-10"
        id="deco-der"
      >
        <svg viewBox="0 0 120 120" class="w-full h-auto opacity-70">
          <ellipse cx="60" cy="60" rx="50" ry="35" fill="#6B8E6B" opacity="0.6"
          ></ellipse>
          <ellipse cx="60" cy="60" rx="40" ry="28" fill="#D4AF37" opacity="0.3"
          ></ellipse>
          <circle cx="60" cy="60" r="12" fill="#D4AF37" opacity="0.8"></circle>
        </svg>
      </div>

      <!-- CARD PRINCIPAL CON GLASS EFFECT MEJORADO -->
      <div
        class="relative card-glass rounded-[2rem] sm:rounded-[2rem] border border-[#6B8E6B]/20 py-8 sm:py-8 md:py-8 px-8 sm:px-8 md:px-8 z-10 max-w-sm sm:max-w-sm md:max-w-sm mx-auto shadow-2xl"
        id="card-contador"
      >
        <!-- CONTADOR -->
        <div class="relative" id="contador-container">
          <div class="flex items-center justify-center gap-3 sm:gap-3 md:gap-3">
            <!-- DÍAS -->
            <div class="flex flex-col items-center grupo-tiempo">
              <div
                class="font-charm text-4xl sm:text-4xl md:text-4xl lg:text-4xl font-bold leading-none numero-uniforme"
                id="dias"
              >
                00
              </div>
              <div
                class="text-xs sm:text-xs md:text-xs lg:text-xs text-[#6B8E6B] uppercase tracking-widest font-charm mt-2 sm:mt-3 font-semibold"
              >
                Días
              </div>
            </div>

            <!-- SEPARADOR -->
            <div
              class="text-3xl sm:text-3xl md:text-3xl text-[#D4AF37]/50 font-thin separador"
            >
              :
            </div>

            <!-- HORAS -->
            <div class="flex flex-col items-center grupo-tiempo">
              <div
                class="font-charm text-4xl sm:text-4xl md:text-4xl lg:text-4xl font-bold leading-none numero-uniforme"
                id="horas"
              >
                00
